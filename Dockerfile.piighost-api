# Thin layer over the public piighost-api image that bakes our pipeline.toml
# into the image at /app/pipeline.toml. We do this instead of a bind-mount
# because Coolify's compose runner doesn't reliably resolve `./pipeline.toml`
# to the cloned repo directory on every redeploy.
#
# /app/pipeline.toml is the default PIIGHOST_CONFIG path baked into the
# upstream image, so no env override is needed.
FROM ghcr.io/athroniaeth/piighost-api:latest

COPY pipeline.toml /app/pipeline.toml
