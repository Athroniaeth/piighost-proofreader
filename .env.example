# Required: LLM credentials used by the FastAPI backend.
LITELLM_MODEL=gpt-4o-mini
LITELLM_API_KEY=
LITELLM_API_BASE=

# Optional: API key enforced by piighost-api (leave empty to disable auth).
PIIGHOST_API_KEY=

# Only needed when the backend runs on the host (dev mode) and reaches
# piighost-api via localhost. Inside docker compose the backend already
# uses http://piighost-api:8000 (service name on the docker network).
PIIGHOST_API_URL=http://localhost:8000
